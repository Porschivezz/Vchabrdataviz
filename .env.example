# === Database ===
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/monitoring

# === OpenRouter LLM ===
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model for summarization / NER
LLM_MODEL=openai/gpt-4o-mini
# Model for embeddings
EMBEDDING_MODEL=openai/text-embedding-3-small

# Cost per 1M tokens (USD) — adjust to current OpenRouter pricing
LLM_INPUT_COST_PER_1M=0.15
LLM_OUTPUT_COST_PER_1M=0.60
EMBEDDING_COST_PER_1M=0.02

# === Auto-Trigger Keywords (comma-separated, case-insensitive) ===
AUTO_ANALYZE_KEYWORDS=python,машинное обучение,ml,ai,data science,нейросети,llm,gpt,deep learning,аналитика

# === Admin ===
ADMIN_PASSWORD=changeme123
