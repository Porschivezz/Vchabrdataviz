# RU News Collector — environment variables
# Copy to .env and fill in values

# PostgreSQL on the Russian VPS
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ru_news

# API auth token — must match the token configured on the EU app side
API_TOKEN=change-me-to-a-long-random-string

# How often to poll sources (minutes)
POLL_INTERVAL_MINUTES=15

# Bind address for the API server
API_HOST=0.0.0.0
API_PORT=8100

# Apify (for TASS and other JS-heavy sites behind WAF)
# Get token at https://console.apify.com/account/integrations
APIFY_TOKEN=
# Max pages per Apify run (cost control, ~$0.25-0.50 per 50 pages)
APIFY_MAX_PAGES_PER_RUN=50
